# Copy this file to .env and fill in the values before running docker-compose

JWT_SECRET=change-me-32-chars-minimum
JWT_REFRESH_SECRET=change-me-32-chars-minimum-refresh

ANTHROPIC_API_KEY=sk-ant-...

# URL the browser uses to reach the backend
VITE_API_URL=http://localhost:3001

# URL the backend uses for CORS (where the frontend is served)
CLIENT_URL=http://localhost:5173
